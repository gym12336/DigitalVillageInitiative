# ============================================================
# 后端环境变量示例。复制为 .env 后填入真实值（.env 不入仓）。
# ============================================================

# JWT 签名密钥——生产务必换成足够长的随机串。
JWT_SECRET=dev-only-change-me-in-production

# 后端监听端口（Vite proxy 默认转发到此）。
PORT=3001

# ---- AI 内容生成 ----
# DeepSeek API 密钥（OpenAI 兼容）。用于村庄介绍/事实/标签 AI 生成。
# 留空则 AI 增强功能不可用。
DEEPSEEK_API_KEY=
# 博查AI Search API 密钥（https://open.bochaai.com 申请）。留空则联网搜索静默跳过。
BOCHA_API_KEY=

# ---- 地图 & 高程 API ----
# 高德地图 Web 服务 Key（优先用于国内坐标海拔查询）。
# 申请地址：https://lbs.amap.com/api/webservice/
AMAP_API_KEY=

# 腾讯地图 WebService Key（高程查询备选）。
# 申请地址：https://lbs.qq.com/service/webService/
TENCENT_MAP_KEY=
# ---- 3D 地图组件 ----
# 天地图 API Key（https://console.tianditu.gov.cn 申请）
TIANDITU_KEY=
# Cesium Ion Token（https://ion.cesium.com 申请）
CESIUM_ION_TOKEN=
